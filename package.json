{
  "name": "htest.dev",
  "version": "0.0.24",
  "description": "Declarative, boilerplate-free unit testing, for everyone",
  "files": [
    "src/",
    "bin/",
    "htest.js",
    "htest.css",
    "SKILL.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "bin/htest.js tests/index.js",
    "build:html": "npx @11ty/eleventy --config=_build/eleventy.js",
    "watch:html": "npx @11ty/eleventy --config=_build/eleventy.js --watch",
    "build": "npm run build:docs && npm run build:html",
    "build:docs": "npx typedoc",
    "watch:docs": "npx typedoc --watch --preserveWatchOutput",
    "watch": "npm run watch:html",
    "dev": "npx @11ty/eleventy --config=_build/eleventy.js --serve",
    "eslint": "npx eslint .",
    "eslint:fix": "npx eslint . --fix",
    "release": "npm login && release-it"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./check": {
      "import": "./src/check.js"
    },
    "./map": {
      "import": "./src/map.js"
    },
    "./env": {
      "import": "./src/env/index.js"
    }
  },
  "bin": {
    "htest": "bin/htest.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/htest-dev/htest.git"
  },
  "keywords": [],
  "author": "Lea Verou",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/htest-dev/htest/issues"
  },
  "homepage": "https://htest.dev",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@stylistic/eslint-plugin": "latest",
    "eleventy-plugin-toc": "^1.1.5",
    "eslint": "latest",
    "globals": "latest",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "release-it": "latest",
    "typedoc": "^0.28"
  },
  "dependencies": {
    "diff": "^8.0.4",
    "glob": "^13.0.6",
    "log-update": "^6.1.0",
    "oo-ascii-tree": "^1.127.0"
  }
}
